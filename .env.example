# ─────────────────────────────────────────────────────────────────────────────
# TechpioAsset - environment template
#
# Copy to `.env` and adjust. `.env` is git-ignored and must never be committed.
# Every variable the application reads is listed here (spec section 28: add
# environment-variable documentation).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://techpioasset:techpioasset@localhost:5432/techpioasset?schema=public

# ── Redis (cache, BullMQ queues, rate limiting) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Encrypts TOTP secrets at rest. 32 bytes, base64url.
MFA_ENCRYPTION_KEY=change-me-mfa-encryption-key-32-bytes-base64url
PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Optional Microsoft Entra ID SSO. Leave blank to disable.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
# memory (per-process) or redis (shared across instances, needs REDIS_URL)
RATE_LIMIT_STORAGE=memory
# Reference-data cache: memory or redis
CACHE_PROVIDER=memory
CACHE_TTL_SECONDS=60

# ── File storage ─────────────────────────────────────────────────────────────
# local | azure | s3   ("local" writes to .local-storage and marks responses simulated)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=.local-storage
STORAGE_CONTAINER=techpioasset
STORAGE_SIGNED_URL_TTL_SECONDS=300
MAX_UPLOAD_MB=25
# Comma-separated. Spec section 8 permits PDF, JPG, JPEG, PNG, HEIC.
ALLOWED_UPLOAD_MIME=application/pdf,image/jpeg,image/png,image/heic

# Azure Blob (STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=
# Amazon S3 (STORAGE_PROVIDER=s3)
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── AI document intelligence ─────────────────────────────────────────────────
# mock | azure   ("mock" performs no external call and marks results simulated)
AI_PROVIDER=mock
# Master kill switch. Even when true, per-company settings still apply and the
# Super Admin AI configuration page governs individual features.
AI_ENABLED=false
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=
AI_CONFIDENCE_THRESHOLD=0.85
AI_MONTHLY_BUDGET_USD=

# ── Email ────────────────────────────────────────────────────────────────────
# mock | smtp   ("mock" writes .eml files to .local-mail)
MAIL_PROVIDER=mock
MAIL_FROM="TechpioAsset <no-reply@techpioasset.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ── Background jobs ──────────────────────────────────────────────────────────
# in-process | bullmq
#   in-process : runs jobs in the API process. No Redis needed, but jobs do not
#                survive a restart and do not distribute across instances.
#   bullmq     : durable queue on REDIS_URL. Use this in any real deployment.
QUEUE_PROVIDER=in-process

# ── Push notifications ───────────────────────────────────────────────────────
# mock | expo
PUSH_PROVIDER=mock
EXPO_ACCESS_TOKEN=

# ── Optional chat integrations (spec section 19) ─────────────────────────────
# mock | webhook   ("webhook" posts to a company's configured Teams/Slack URL)
CHAT_PROVIDER=mock
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Scheduled jobs ───────────────────────────────────────────────────────────
# Runs the warranty-expiry and maintenance-due alert sweep (spec section 14).
# Off by default so multiple dev instances do not each fire the sweep.
ENABLE_SCHEDULED_JOBS=false

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
# Never log these keys' values.
LOG_REDACT_KEYS=password,passwordHash,token,accessToken,refreshToken,mfaSecret,authorization,cookie

# ── Web (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=TechpioAsset
