// TechpioAsset - database schema
// Implements PLAN.md section 3 / spec section 23.
//
// Conventions applied throughout:
//   * Tenancy      - every tenant-owned model carries `companyId`. A Prisma client
//                    extension injects the filter; no query may omit it.
//   * Soft delete  - `deletedAt` where the spec permits archival (section 22).
//                    Financial, assignment and audit rows have no delete path at all.
//   * Concurrency  - `version Int` on contended rows for optimistic locking.
//   * Provenance   - `createdById` / `updatedById` are scalar references rather than
//                    foreign keys. Users are never hard-deleted (section 22), so these
//                    cannot dangle, and modelling them as relations would add ~80
//                    back-relation fields to User for no integrity gain. Semantic
//                    references (assignee, reviewer, approver) ARE real foreign keys.
//   * Money        - Decimal(14,2), never Float. Quantity is Decimal(14,3) so
//                    consumables can be issued fractionally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum VerificationPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum TrackingType {
  INDIVIDUAL
  QUANTITY
}

/// Spec section 7 - 18 statuses. Mirrors @techpioasset/domain AssetStatus.
enum AssetStatus {
  DRAFT
  REQUESTED
  ORDERED
  RECEIVED
  AVAILABLE
  RESERVED
  ASSIGNED
  IN_USE
  IN_STORAGE
  IN_TRANSIT
  UNDER_REPAIR
  DAMAGED
  LOST
  STOLEN
  RETURNED
  RETIRED
  DISPOSED
  DONATED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
  UNUSABLE
}

enum DepreciationMethod {
  NONE
  STRAIGHT_LINE
  DECLINING_BALANCE
}

/// Spec section 11 - 16 statuses. Mirrors @techpioasset/domain RequestStatus.
enum RequestStatus {
  DRAFT
  SUBMITTED
  MANAGER_APPROVAL_PENDING
  HR_REVIEW_PENDING
  IT_REVIEW_PENDING
  OFFICE_ADMIN_REVIEW_PENDING
  FINANCE_APPROVAL_PENDING
  APPROVED
  REJECTED
  INVENTORY_RESERVED
  ORDERED
  RECEIVED
  READY_FOR_ASSIGNMENT
  ASSIGNED
  COMPLETED
  CANCELLED
}

/// Spec section 11 - request types.
enum RequestType {
  NEW_EMPLOYEE_ONBOARDING
  REPLACEMENT
  DAMAGE
  LOSS
  UPGRADE
  TEMPORARY_ASSIGNMENT
  PROJECT_REQUIREMENT
  OFFICE_REQUIREMENT
  KITCHEN_REQUIREMENT
  ACCESSIBILITY_REQUIREMENT
  ADDITIONAL_EQUIPMENT
  REPAIR
  RETURN
}

enum RequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ApprovalDecision {
  /// Queued behind an earlier step. Not yet on anyone's desk, and deliberately
  /// distinct from PENDING: without the distinction every future approver sees a
  /// request in their inbox the moment it is submitted.
  WAITING
  /// Currently awaiting this step's approver. At most one per request.
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  DELEGATED
}

enum ApproverType {
  ROLE
  USER
  LINE_MANAGER
  DEPARTMENT_HEAD
}

/// Spec section 9 - 16 statuses. Mirrors @techpioasset/domain VerificationStatus.
enum VerificationStatus {
  UPLOADED
  PENDING_AI_PROCESSING
  AI_PROCESSING
  AI_FAILED
  EXTRACTION_COMPLETED
  PENDING_REVIEW
  MATCHED
  PARTIALLY_MATCHED
  DUPLICATE_SUSPECTED
  ASSET_MISSING
  QUANTITY_MISMATCH
  COST_MISMATCH
  SERIAL_NUMBER_MISMATCH
  MANUAL_REVIEW_REQUIRED
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHEQUE
  DIRECT_DEBIT
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

/// Malware-scanning hook state (spec section 1: malware-scanning hooks).
enum DocumentScanStatus {
  PENDING
  CLEAN
  INFECTED
  SKIPPED
  FAILED
}

enum MaintenanceType {
  SCHEDULED
  REPAIR
  INSPECTION
  WARRANTY_CLAIM
  CALIBRATION
  CLEANING
}

enum MaintenanceStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FAILED
}

enum DisposalMethod {
  SOLD
  SCRAPPED
  RECYCLED
  DONATED
  RETURNED_TO_VENDOR
  WRITTEN_OFF
}

enum TransferType {
  EMPLOYEE
  DEPARTMENT
  ROOM
  OFFICE
  LEGAL_ENTITY
}

enum InventoryTransactionReason {
  PURCHASE
  ISSUE
  RETURN
  ADJUSTMENT
  STOCKTAKE
  WASTAGE
  TRANSFER_IN
  TRANSFER_OUT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  TEAMS
  SLACK
}

/// Spec section 19 - notification triggers.
enum NotificationType {
  NEW_REQUEST
  APPROVAL_REQUIRED
  REQUEST_APPROVED
  REQUEST_REJECTED
  ASSET_ORDERED
  ASSET_RECEIVED
  ASSET_READY
  ASSET_ASSIGNED
  RECEIPT_CONFIRMATION
  RETURN_REQUIRED
  RETURN_OVERDUE
  DAMAGE_REPORTED
  INVOICE_UPLOADED
  AI_PROCESSING_COMPLETED
  AI_PROCESSING_FAILED
  INVOICE_MISMATCH
  WARRANTY_EXPIRATION
  MAINTENANCE_DUE
  LOW_STOCK
  REPLACEMENT_DUE
  SECURITY_ALERT
}

/// Spec section 10 - individually switchable AI features.
enum AiFeature {
  INVOICE_OCR
  INVOICE_FIELD_EXTRACTION
  LINE_ITEM_EXTRACTION
  CATEGORY_SUGGESTION
  VENDOR_SUGGESTION
  INVOICE_TO_ASSET_MATCHING
  DUPLICATE_WARNING
  WARRANTY_EXTRACTION
  DRAFT_ASSET_CREATION
  AI_SUMMARIES
  AI_ASSISTANT
  SEMANTIC_SEARCH
}

/// Spec section 10 - per-feature modes.
enum AiFeatureMode {
  DISABLED
  SUGGESTION_ONLY
  MANUAL_REVIEW_REQUIRED
  AUTOMATIC_PROCESSING
  RESTRICTED_TO_ROLES
}

/// Spec section 21 - audited actions.
enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  PASSWORD_RESET
  MFA_ENROLLED
  MFA_DISABLED
  USER_CREATED
  USER_UPDATED
  ROLE_CHANGED
  PERMISSION_CHANGED
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_STATUS_CHANGED
  ASSET_COST_CHANGED
  ASSIGNMENT_CREATED
  ASSIGNMENT_RETURNED
  ASSET_TRANSFERRED
  INVENTORY_ADJUSTED
  INVOICE_UPLOADED
  INVOICE_UPDATED
  INVOICE_ARCHIVED
  AI_PROCESSING
  AI_CORRECTION
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  DISPOSAL_RECORDED
  DATA_EXPORTED
  SETTING_CHANGED
  DOCUMENT_DOWNLOADED
}

enum PhysicalInventoryStatus {
  OPEN
  IN_PROGRESS
  RECONCILING
  CLOSED
  CANCELLED
}

enum PhysicalInventoryScanResult {
  EXPECTED
  UNEXPECTED_LOCATION
  NOT_IN_REGISTER
  DUPLICATE_SCAN
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity and access
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id           String   @id @default(cuid())
  name         String
  legalName    String?
  taxId        String?
  baseCurrency String   @default("USD") @db.Char(3)
  locale       String   @default("en-US")
  timezone     String   @default("UTC")
  logoKey      String?
  isActive     Boolean  @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  users                    User[]
  offices                  Office[]
  departments              Department[]
  categories               Category[]
  assets                   Asset[]
  inventoryItems           InventoryItem[]
  vendors                  Vendor[]
  invoices                 Invoice[]
  purchaseOrders           PurchaseOrder[]
  requests                 AssetRequest[]
  roles                    Role[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  attachments              Attachment[]
  aiConfiguration          AIConfiguration?
  aiUsageRecords           AIUsageRecord[]
  workflowDefinitions      WorkflowDefinition[]
  onboardingTemplates      OnboardingTemplate[]
  savedFilters             SavedFilter[]
  scheduledReports         ScheduledReport[]
  physicalInventorySessions PhysicalInventorySession[]

  @@index([deletedAt])
  @@map("companies")
}

model User {
  id        String @id @default(cuid())
  companyId String

  email        String
  passwordHash String?
  status       UserStatus @default(INVITED)

  emailVerifiedAt DateTime?
  /// Encrypted at rest by the application before persistence; never returned by any endpoint.
  mfaSecret       String?
  mfaEnabledAt    DateTime?

  /// Brute-force protection (spec section 20).
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  /// Optional Microsoft Entra ID subject claim for SSO users.
  externalIdpSubject String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  profile UserProfile?
  roles   UserRole[]

  refreshTokens           RefreshToken[]
  verificationTokens      VerificationToken[]
  assignedAssets          Asset[]                 @relation("AssetCurrentAssignee")
  assignmentsHeld         AssetAssignment[]       @relation("AssignmentHolder")
  assignmentsGranted      AssetAssignment[]       @relation("AssignmentGrantedBy")
  returnsReceived         AssetReturn[]           @relation("ReturnReceivedBy")
  transfersFrom           AssetTransfer[]         @relation("TransferFromUser")
  transfersTo             AssetTransfer[]         @relation("TransferToUser")
  transfersApproved       AssetTransfer[]         @relation("TransferApprovedBy")
  requestsRaised          AssetRequest[]          @relation("RequestRequester")
  requestsOnBehalf        AssetRequest[]          @relation("RequestBeneficiary")
  requestsManaged         AssetRequest[]          @relation("RequestManager")
  approvals               RequestApproval[]       @relation("ApprovalApprover")
  requestComments         RequestComment[]
  invoicesReviewed        Invoice[]               @relation("InvoiceReviewer")
  invoiceDocumentsUploaded InvoiceDocument[]      @relation("DocumentUploader")
  verificationsDecided    InvoiceVerification[]   @relation("VerificationDecider")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  auditLogs               AuditLog[]              @relation("AuditActor")
  aiUsageRecords          AIUsageRecord[]
  disposalsApproved       DisposalRecord[]        @relation("DisposalApprover")
  onboardingTasks         OnboardingTask[]        @relation("OnboardingSubject")
  maintenanceRequested    MaintenanceRecord[]     @relation("MaintenanceRequester")
  inventoryTransactions   InventoryTransaction[]  @relation("InventoryActor")
  physicalInventoryScans  PhysicalInventoryScan[] @relation("ScanBy")
  physicalInventoryLed    PhysicalInventorySession[] @relation("SessionOwner")
  savedFilters            SavedFilter[]
  scheduledReports        ScheduledReport[]
  directReports           UserProfile[]           @relation("LineManager")

  /// Email is unique per tenant, not globally: the same person may exist in two companies.
  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([externalIdpSubject])
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  firstName      String
  lastName       String
  displayName    String?
  employeeNumber String?
  jobTitle       String?
  phone          String?
  /// Object-storage key. Served only via a signed URL; never a public path.
  avatarKey      String?
  hireDate       DateTime?
  terminationDate DateTime?

  departmentId String?
  officeId     String?
  managerId    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  office     Office?     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  manager    User?       @relation("LineManager", fields: [managerId], references: [id], onDelete: SetNull)

  @@index([departmentId])
  @@index([officeId])
  @@index([managerId])
  @@index([employeeNumber])
  @@map("user_profiles")
}

model Role {
  id        String  @id @default(cuid())
  companyId String
  key       String
  name      String
  description String?
  /// System roles are seeded and may not be deleted, only re-granted.
  isSystem  Boolean @default(false)
  /// Auditor is read-only: the API refuses to attach a write permission to it.
  isReadOnly Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]
  workflowSteps WorkflowStep[]    @relation("StepApproverRole")
  approvalSteps RequestApproval[] @relation("ApprovalApproverRole")

  @@unique([companyId, key])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  /// `resource:action`, e.g. `assets:assign`. Global, not per-tenant.
  key         String  @unique
  resource    String
  action      String
  description String?
  /// Read-only permissions are the only ones grantable to a read-only role.
  isReadOnly  Boolean @default(false)

  createdAt DateTime @default(now())

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  createdAt   DateTime @default(now())
  createdById String?

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String

  createdAt   DateTime @default(now())
  createdById String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

/// Refresh-token rotation (spec section 1). One row per issued token; a reused
/// token revokes its whole family, which is how replay is detected.
model RefreshToken {
  id        String  @id @default(cuid())
  userId    String
  /// SHA-256 of the token. The raw value is never stored.
  tokenHash String  @unique
  familyId  String

  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  rotatedAt DateTime?
  revokedAt DateTime?
  revokedReason String?

  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Single-use tokens for email verification and password reset (spec section 1).
/// Only the SHA-256 hash is stored: a leaked table must not yield usable tokens,
/// which is the same reasoning as RefreshToken.
model VerificationToken {
  id        String              @id @default(cuid())
  userId    String
  tokenHash String              @unique
  purpose   VerificationPurpose

  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Organisation and locations
// ─────────────────────────────────────────────────────────────────────────────

model Office {
  id        String  @id @default(cuid())
  companyId String
  code      String
  name      String
  addressLine1 String?
  addressLine2 String?
  city      String?
  region    String?
  postalCode String?
  country   String?
  timezone  String?
  isActive  Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buildings Building[]
  assets    Asset[]
  inventoryItems InventoryItem[]
  profiles  UserProfile[]
  requests  AssetRequest[]
  departments Department[]
  transfersFrom AssetTransfer[] @relation("TransferFromOffice")
  transfersTo   AssetTransfer[] @relation("TransferToOffice")
  physicalInventorySessions PhysicalInventorySession[]
  aiOverrides AIFeatureOverride[]

  @@unique([companyId, code])
  @@index([deletedAt])
  @@map("offices")
}

model Building {
  id       String @id @default(cuid())
  officeId String
  name     String
  code     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  office Office  @relation(fields: [officeId], references: [id], onDelete: Cascade)
  floors Floor[]
  assets Asset[]

  @@unique([officeId, name])
  @@map("buildings")
}

model Floor {
  id         String @id @default(cuid())
  buildingId String
  name       String
  level      Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms    Room[]
  assets   Asset[]

  @@unique([buildingId, name])
  @@map("floors")
}

model Room {
  id      String @id @default(cuid())
  floorId String
  name    String
  code    String?
  /// Rooms double as storage locations for quantity-tracked stock.
  isStorageLocation Boolean @default(false)
  capacity Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  floor          Floor           @relation(fields: [floorId], references: [id], onDelete: Cascade)
  assets         Asset[]
  inventoryItems InventoryItem[]
  transfersFrom  AssetTransfer[] @relation("TransferFromRoom")
  transfersTo    AssetTransfer[] @relation("TransferToRoom")

  @@unique([floorId, name])
  @@map("rooms")
}

model Department {
  id        String  @id @default(cuid())
  companyId String
  code      String
  name      String
  parentId  String?
  officeId  String?
  costCentre String?
  isActive  Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentTree")
  office   Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)

  profiles      UserProfile[]
  assets        Asset[]
  requests      AssetRequest[]
  transfersFrom AssetTransfer[] @relation("TransferFromDepartment")
  transfersTo   AssetTransfer[] @relation("TransferToDepartment")

  @@unique([companyId, code])
  @@index([parentId])
  @@map("departments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalogue
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id        String  @id @default(cuid())
  companyId String
  key       String
  name      String
  /// Lucide icon name, kept consistent with @techpioasset/ui-tokens.
  icon      String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  /// Default tracking model for items created under this category.
  defaultTrackingType TrackingType @default(INDIVIDUAL)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  assets        Asset[]
  inventoryItems InventoryItem[]
  requestItems  RequestItem[]
  invoiceLines  InvoiceLine[]  @relation("SuggestedCategory")

  @@unique([companyId, key])
  @@index([companyId, isActive, sortOrder])
  @@map("categories")
}

model Subcategory {
  id         String  @id @default(cuid())
  categoryId String
  key        String
  name       String
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assets         Asset[]
  inventoryItems InventoryItem[]
  requestItems   RequestItem[]

  @@unique([categoryId, key])
  @@map("subcategories")
}

// ─────────────────────────────────────────────────────────────────────────────
// Assets
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id        String @id @default(cuid())
  companyId String

  assetTag     String
  name         String
  description  String?
  categoryId   String
  subcategoryId String?
  trackingType TrackingType @default(INDIVIDUAL)

  brand                 String?
  model                 String?
  serialNumber          String?
  manufacturerPartNumber String?
  barcode               String?
  /// Opaque ULID. QR codes encode this, never asset data - spec section 15
  /// forbids exposing asset information through a public QR URL.
  qrToken               String @unique

  purchaseDate       DateTime?
  purchaseCost       Decimal?  @db.Decimal(14, 2)
  currency           String?   @db.Char(3)
  currentValue       Decimal?  @db.Decimal(14, 2)
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeMonths   Int?
  salvageValue       Decimal?  @db.Decimal(14, 2)

  vendorId      String?
  invoiceLineId String?
  purchaseOrderNumber String?

  warrantyStartDate      DateTime?
  warrantyEndDate        DateTime?
  expectedReplacementDate DateTime?

  officeId     String?
  buildingId   String?
  floorId      String?
  roomId       String?
  departmentId String?

  assignedUserId String?
  assignmentDate DateTime?
  expectedReturnDate DateTime?

  condition AssetCondition @default(GOOD)
  status    AssetStatus    @default(DRAFT)
  notes     String?

  /// Set only when an authorised user records a documented duplicate exception
  /// (spec section 6). Null means the uniqueness rule was satisfied normally.
  duplicateExceptionReason String?
  duplicateExceptionById   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  invoiceLine  InvoiceLine? @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)
  office       Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
  building     Building?    @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  floor        Floor?       @relation(fields: [floorId], references: [id], onDelete: SetNull)
  room         Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedUser User?        @relation("AssetCurrentAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  assignments      AssetAssignment[]
  transfers        AssetTransfer[]
  conditionLogs    AssetConditionLog[]
  maintenance      MaintenanceRecord[]
  warranties       Warranty[]
  disposal         DisposalRecord?
  invoiceLinks     AssetInvoiceLink[]
  attachments      Attachment[]
  replacementFor   AssetRequest[]      @relation("RequestReplacesAsset")
  fulfilledItems   RequestItem[]       @relation("RequestItemFulfilledAsset")
  inventoryScans   PhysicalInventoryScan[]

  /// Postgres treats NULLs as distinct in a unique index, so quantity-tracked
  /// rows (which carry no serial) coexist freely while real serials stay unique.
  @@unique([companyId, assetTag])
  @@unique([companyId, serialNumber])
  @@index([companyId, status])
  @@index([companyId, categoryId])
  @@index([companyId, assignedUserId])
  @@index([companyId, officeId])
  @@index([companyId, departmentId])
  @@index([companyId, warrantyEndDate])
  @@index([companyId, deletedAt])
  @@index([barcode])
  @@map("assets")
}

model InventoryItem {
  id        String @id @default(cuid())
  companyId String

  sku           String
  name          String
  description   String?
  categoryId    String
  subcategoryId String?

  unit           String  @default("unit")
  quantityOnHand Decimal @default(0) @db.Decimal(14, 3)
  quantityIssued Decimal @default(0) @db.Decimal(14, 3)
  minStock       Decimal? @db.Decimal(14, 3)
  reorderLevel   Decimal? @db.Decimal(14, 3)

  unitCost         Decimal? @db.Decimal(14, 2)
  averageCost      Decimal? @db.Decimal(14, 2)
  currency         String?  @db.Char(3)
  lastPurchaseDate DateTime?

  officeId String?
  roomId   String?

  isActive Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  office      Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
  room        Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)

  transactions InventoryTransaction[]
  invoiceLinks AssetInvoiceLink[]

  @@unique([companyId, sku])
  @@index([companyId, categoryId])
  @@index([companyId, deletedAt])
  @@map("inventory_items")
}

/// Append-only ledger behind `InventoryItem.quantityOnHand`. Without it a stock
/// balance is a number nobody can explain; with it every movement is attributable.
model InventoryTransaction {
  id              String @id @default(cuid())
  inventoryItemId String

  reason        InventoryTransactionReason
  /// Signed: positive receives stock, negative issues it.
  quantityDelta Decimal @db.Decimal(14, 3)
  balanceAfter  Decimal @db.Decimal(14, 3)
  unitCost      Decimal? @db.Decimal(14, 2)

  referenceType String?
  referenceId   String?
  note          String?

  actorId   String?
  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  actor         User?         @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, createdAt])
  @@map("inventory_transactions")
}

model AssetAssignment {
  id      String @id @default(cuid())
  assetId String
  userId  String

  assignedById       String?
  assignedAt         DateTime  @default(now())
  expectedReturnAt   DateTime?
  conditionOut       AssetCondition
  accessoriesIssued  String?
  notes              String?

  /// Employee receipt confirmation (spec section 12: capture acknowledgment).
  acknowledgedAt        DateTime?
  acknowledgementMethod String?
  acknowledgementIp     String?

  returnedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  asset      Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user       User         @relation("AssignmentHolder", fields: [userId], references: [id], onDelete: Restrict)
  assignedBy User?        @relation("AssignmentGrantedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  assetReturn AssetReturn?

  @@index([assetId, assignedAt])
  @@index([userId, returnedAt])
  @@map("asset_assignments")
}

model AssetReturn {
  id           String @id @default(cuid())
  assignmentId String @unique

  returnedAt         DateTime @default(now())
  receivedById       String?
  conditionIn        AssetCondition
  missingAccessories String?
  damageNotes        String?
  resultingStatus    AssetStatus

  acknowledgedAt DateTime?
  notes          String?

  createdAt   DateTime @default(now())
  createdById String?

  assignment AssetAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  receivedBy User?           @relation("ReturnReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  @@map("asset_returns")
}

/// Spec section 12: "Do not overwrite history." Every transfer is a new row
/// recording both sides of the move.
model AssetTransfer {
  id      String @id @default(cuid())
  assetId String

  transferType TransferType

  fromUserId       String?
  toUserId         String?
  fromDepartmentId String?
  toDepartmentId   String?
  fromRoomId       String?
  toRoomId         String?
  fromOfficeId     String?
  toOfficeId       String?
  fromCompanyId    String?
  toCompanyId      String?

  transferredAt DateTime @default(now())
  approvedById  String?
  reason        String?
  condition     AssetCondition?
  notes         String?

  createdAt   DateTime @default(now())
  createdById String?

  asset          Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromUser       User?       @relation("TransferFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser         User?       @relation("TransferToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  approvedBy     User?       @relation("TransferApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  fromDepartment Department? @relation("TransferFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: SetNull)
  toDepartment   Department? @relation("TransferToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  fromRoom       Room?       @relation("TransferFromRoom", fields: [fromRoomId], references: [id], onDelete: SetNull)
  toRoom         Room?       @relation("TransferToRoom", fields: [toRoomId], references: [id], onDelete: SetNull)
  fromOffice     Office?     @relation("TransferFromOffice", fields: [fromOfficeId], references: [id], onDelete: SetNull)
  toOffice       Office?     @relation("TransferToOffice", fields: [toOfficeId], references: [id], onDelete: SetNull)

  @@index([assetId, transferredAt])
  @@map("asset_transfers")
}

model AssetConditionLog {
  id      String @id @default(cuid())
  assetId String

  previousCondition AssetCondition?
  newCondition      AssetCondition
  previousStatus    AssetStatus?
  newStatus         AssetStatus?
  reason            String?
  photosJson        Json?

  recordedAt  DateTime @default(now())
  createdById String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, recordedAt])
  @@map("asset_condition_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Maintenance, warranty, disposal
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id      String @id @default(cuid())
  assetId String

  type   MaintenanceType
  status MaintenanceStatus @default(REQUESTED)

  title       String
  description String?
  requestedById String?
  vendorId    String?
  isInternal  Boolean @default(false)

  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  serviceCost   Decimal? @db.Decimal(14, 2)
  currency      String?  @db.Char(3)
  downtimeHours Decimal? @db.Decimal(8, 2)

  warrantyId              String?
  replacementRecommended  Boolean @default(false)
  recommendationNote      String?
  resolutionNotes         String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  asset       Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vendor      Vendor?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  requestedBy User?      @relation("MaintenanceRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  warranty    Warranty?  @relation(fields: [warrantyId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([assetId, status])
  @@index([scheduledFor])
  @@map("maintenance_records")
}

model Warranty {
  id      String @id @default(cuid())
  assetId String

  provider     String?
  policyNumber String?
  startDate    DateTime
  endDate      DateTime
  coverageNotes String?
  isActive     Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  asset       Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  claims      MaintenanceRecord[]

  @@index([assetId])
  @@index([endDate])
  @@map("warranties")
}

/// Spec section 22: disposal is recorded, never a delete.
model DisposalRecord {
  id      String @id @default(cuid())
  assetId String @unique

  method       DisposalMethod
  disposedAt   DateTime
  proceeds     Decimal? @db.Decimal(14, 2)
  currency     String?  @db.Char(3)
  recipient    String?
  reason       String
  approvedById String?
  certificateKey String?

  createdAt   DateTime @default(now())
  createdById String?

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  approvedBy User? @relation("DisposalApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("disposal_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// Procurement and invoices
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id        String @id @default(cuid())
  companyId String

  code         String
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  taxId        String?
  addressLine1 String?
  city         String?
  country      String?
  notes        String?
  isActive     Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets         Asset[]
  invoices       Invoice[]
  purchaseOrders PurchaseOrder[]
  maintenance    MaintenanceRecord[]

  @@unique([companyId, code])
  @@index([companyId, name])
  @@map("vendors")
}

model PurchaseOrder {
  id        String @id @default(cuid())
  companyId String

  poNumber String
  vendorId String
  status   PurchaseOrderStatus @default(DRAFT)

  issuedDate   DateTime?
  expectedDate DateTime?
  currency     String   @db.Char(3)
  subtotal     Decimal  @default(0) @db.Decimal(14, 2)
  tax          Decimal  @default(0) @db.Decimal(14, 2)
  shipping     Decimal  @default(0) @db.Decimal(14, 2)
  total        Decimal  @default(0) @db.Decimal(14, 2)
  notes        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor  Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines   PurchaseOrderLine[]
  invoices Invoice[]

  @@unique([companyId, poNumber])
  @@index([companyId, status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String @id @default(cuid())
  purchaseOrderId String

  lineNumber  Int
  description String
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)
  receivedQuantity Decimal @default(0) @db.Decimal(14, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, lineNumber])
  @@map("purchase_order_lines")
}

model Invoice {
  id        String @id @default(cuid())
  companyId String

  invoiceNumber String
  vendorId      String
  purchaseOrderId String?

  invoiceDate  DateTime
  purchaseDate DateTime?
  dueDate      DateTime?
  currency     String   @db.Char(3)

  subtotal      Decimal @default(0) @db.Decimal(14, 2)
  discount      Decimal @default(0) @db.Decimal(14, 2)
  tax           Decimal @default(0) @db.Decimal(14, 2)
  shipping      Decimal @default(0) @db.Decimal(14, 2)
  otherCharges  Decimal @default(0) @db.Decimal(14, 2)
  total         Decimal @default(0) @db.Decimal(14, 2)

  paymentStatus PaymentStatus  @default(UNPAID)
  paymentMethod PaymentMethod?
  paidAt        DateTime?

  verificationStatus VerificationStatus @default(UPLOADED)
  reviewerId         String?
  reviewedAt         DateTime?
  reviewNotes        String?

  notes String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor        Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  reviewer      User?                @relation("InvoiceReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  lines         InvoiceLine[]
  documents     InvoiceDocument[]
  extractions   InvoiceExtraction[]
  verifications InvoiceVerification[]

  /// Deterministic duplicate-invoice-number check (spec section 9).
  @@unique([companyId, invoiceNumber])
  @@index([companyId, verificationStatus])
  @@index([companyId, vendorId])
  @@index([companyId, invoiceDate])
  @@index([companyId, paymentStatus])
  @@map("invoices")
}

model InvoiceLine {
  id        String @id @default(cuid())
  invoiceId String

  lineNumber  Int
  description String
  /// AI-normalised description (spec section 9). The original is never overwritten.
  normalizedDescription String?
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 2)
  lineTotal   Decimal @db.Decimal(14, 2)

  serialNumbers  String[]
  warrantyMonths Int?
  suggestedCategoryId String?
  /// 0..1 confidence for the category suggestion; null when AI is disabled.
  suggestionConfidence Decimal? @db.Decimal(4, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice            Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  suggestedCategory  Category? @relation("SuggestedCategory", fields: [suggestedCategoryId], references: [id], onDelete: SetNull)
  assets             Asset[]
  assetLinks         AssetInvoiceLink[]

  @@unique([invoiceId, lineNumber])
  @@map("invoice_lines")
}

model InvoiceDocument {
  id        String @id @default(cuid())
  invoiceId String

  /// Private object-storage key. Never a public URL (spec section 20).
  storageKey   String
  originalName String
  mimeType     String
  sizeBytes    Int
  pageCount    Int?
  /// Deterministic duplicate-file detection (spec section 9).
  sha256       String
  scanStatus   DocumentScanStatus @default(PENDING)
  scanDetail   String?

  uploadedById String?
  uploadedAt   DateTime @default(now())

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([sha256])
  @@map("invoice_documents")
}

/// One row per extraction attempt. Originals are retained alongside corrections
/// so spec section 9's "save the original extraction, corrected values, decision"
/// is satisfied without mutation.
model InvoiceExtraction {
  id        String @id @default(cuid())
  invoiceId String
  documentId String?

  provider  String
  modelName String?
  status    VerificationStatus @default(PENDING_AI_PROCESSING)

  rawPayload       Json?
  extractedFields  Json?
  fieldConfidences Json?
  overallConfidence Decimal? @db.Decimal(4, 3)

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  costUsd     Decimal? @db.Decimal(10, 6)
  errorDetail String?
  /// True when produced by the mock provider (spec section 28).
  simulated   Boolean @default(false)

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@map("invoice_extractions")
}

model InvoiceVerification {
  id        String @id @default(cuid())
  invoiceId String

  /// Output of the deterministic check engine - never the AI's opinion.
  checkResults Json
  issues       Json
  outcome      VerificationStatus

  decidedById String?
  decidedAt   DateTime?
  notes       String?

  createdAt DateTime @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  decidedBy User?   @relation("VerificationDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([invoiceId, createdAt])
  @@map("invoice_verifications")
}

/// Join between an invoice line and what it paid for. One invoice may cover many
/// assets; one asset links to one line (spec section 8).
model AssetInvoiceLink {
  id            String  @id @default(cuid())
  invoiceLineId String
  assetId       String?
  inventoryItemId String?

  matchConfidence Decimal? @db.Decimal(4, 3)
  /// AUTO when proposed by matching, MANUAL when a reviewer linked it.
  matchMethod     String   @default("MANUAL")
  quantityDelta   Decimal? @db.Decimal(14, 3)
  costDelta       Decimal? @db.Decimal(14, 2)

  createdAt   DateTime @default(now())
  createdById String?

  invoiceLine   InvoiceLine    @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  asset         Asset?         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([invoiceLineId, assetId])
  @@index([assetId])
  @@index([inventoryItemId])
  @@map("asset_invoice_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// Requests and workflow
// ─────────────────────────────────────────────────────────────────────────────

model AssetRequest {
  id        String @id @default(cuid())
  companyId String

  requestNumber String
  type          RequestType
  status        RequestStatus   @default(DRAFT)
  priority      RequestPriority @default(NORMAL)

  requesterId    String
  beneficiaryId  String?
  managerId      String?
  officeId       String?
  departmentId   String?

  businessReason String
  requiredBy     DateTime?
  preferredSpec  String?
  isReplacement  Boolean @default(false)
  replacesAssetId String?
  estimatedCost  Decimal? @db.Decimal(14, 2)
  currency       String?  @db.Char(3)
  notes          String?

  submittedAt  DateTime?
  decidedAt    DateTime?
  completedAt  DateTime?

  workflowDefinitionId String?
  currentStepOrder     Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  version     Int       @default(0)

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester   User        @relation("RequestRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  beneficiary User?       @relation("RequestBeneficiary", fields: [beneficiaryId], references: [id], onDelete: SetNull)
  manager     User?       @relation("RequestManager", fields: [managerId], references: [id], onDelete: SetNull)
  office      Office?     @relation(fields: [officeId], references: [id], onDelete: SetNull)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  replacesAsset Asset?    @relation("RequestReplacesAsset", fields: [replacesAssetId], references: [id], onDelete: SetNull)
  workflowDefinition WorkflowDefinition? @relation(fields: [workflowDefinitionId], references: [id], onDelete: SetNull)

  items       RequestItem[]
  approvals   RequestApproval[]
  comments    RequestComment[]
  attachments Attachment[]

  @@unique([companyId, requestNumber])
  @@index([companyId, status])
  @@index([companyId, requesterId])
  @@index([companyId, beneficiaryId])
  @@index([companyId, managerId])
  @@map("asset_requests")
}

model RequestItem {
  id        String @id @default(cuid())
  requestId String

  categoryId    String?
  subcategoryId String?
  description   String
  quantity      Decimal @default(1) @db.Decimal(14, 3)
  preferredSpec String?
  estimatedCost Decimal? @db.Decimal(14, 2)
  fulfilledAssetId String?
  fulfilledAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request       AssetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  fulfilledAsset Asset?      @relation("RequestItemFulfilledAsset", fields: [fulfilledAssetId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@map("request_items")
}

model RequestApproval {
  id        String @id @default(cuid())
  requestId String

  stepOrder    Int
  stepName     String
  approverType ApproverType
  approverRoleId String?
  approverId   String?

  decision   ApprovalDecision @default(WAITING)
  decidedAt  DateTime?
  comment    String?
  slaDueAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request  AssetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User?        @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)
  /// Needed so an "awaiting my decision" query can traverse from the step to the
  /// role's current holders rather than resolving them in application code.
  approverRole Role?    @relation("ApprovalApproverRole", fields: [approverRoleId], references: [id], onDelete: SetNull)

  @@unique([requestId, stepOrder])
  @@index([approverId, decision])
  @@index([approverRoleId, decision])
  @@map("request_approvals")
}

model RequestComment {
  id        String @id @default(cuid())
  requestId String
  authorId  String?

  body       String
  /// Internal notes stay hidden from the requesting employee.
  isInternal Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  request AssetRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@map("request_comments")
}

/// Spec section 11: "Allow Super Admins to configure workflow steps, approvers,
/// thresholds, and bypass rules." That makes the chain data, not code.
model WorkflowDefinition {
  id        String @id @default(cuid())
  companyId String

  key         String
  name        String
  description String?
  /// Null applies the definition to every request type not otherwise matched.
  requestType RequestType?
  isActive    Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps    WorkflowStep[]
  requests AssetRequest[]

  @@unique([companyId, key])
  @@index([companyId, requestType, isActive])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id                   String @id @default(cuid())
  workflowDefinitionId String

  stepOrder    Int
  name         String
  approverType ApproverType
  approverRoleId String?
  approverUserId String?

  /// Step is skipped when the request total is at or below this figure
  /// (spec section 11: kitchen requests need finance approval only above a threshold).
  costThreshold Decimal? @db.Decimal(14, 2)
  isSkippable   Boolean  @default(false)
  slaHours      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowDefinition WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  approverRole       Role?              @relation("StepApproverRole", fields: [approverRoleId], references: [id], onDelete: SetNull)

  @@unique([workflowDefinitionId, stepOrder])
  @@map("workflow_steps")
}

// ─────────────────────────────────────────────────────────────────────────────
// Onboarding and offboarding
// ─────────────────────────────────────────────────────────────────────────────

model OnboardingTemplate {
  id        String @id @default(cuid())
  companyId String

  key          String
  name         String
  departmentId String?
  jobTitle     String?
  isActive     Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?

  company Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   OnboardingTemplateItem[]
  tasks   OnboardingTask[]

  @@unique([companyId, key])
  @@map("onboarding_templates")
}

model OnboardingTemplateItem {
  id         String @id @default(cuid())
  templateId String

  categoryId    String?
  subcategoryId String?
  description   String
  quantity      Decimal @default(1) @db.Decimal(14, 3)
  isRequired    Boolean @default(true)
  sortOrder     Int     @default(0)

  createdAt DateTime @default(now())

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("onboarding_template_items")
}

/// Drives both onboarding and offboarding checklists. Spec section 13: offboarding
/// cannot complete until every required asset has an outcome or approved exception.
model OnboardingTask {
  id         String @id @default(cuid())
  companyId  String
  templateId String?
  subjectUserId String

  /// ONBOARDING or OFFBOARDING.
  direction String
  status    String @default("OPEN")

  startedAt   DateTime  @default(now())
  dueAt       DateTime?
  completedAt DateTime?

  /// Set when an unresolved asset is signed off deliberately rather than returned.
  exceptionReason   String?
  exceptionApprovedById String?

  checklistJson Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  template    OnboardingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subjectUser User                @relation("OnboardingSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)

  @@index([companyId, direction, status])
  @@index([subjectUserId])
  @@map("onboarding_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications, attachments, AI, audit
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String @id @default(cuid())
  companyId String
  userId    String

  type    NotificationType
  channel NotificationChannel @default(IN_APP)
  title   String
  body    String
  /// Deep link into web or mobile.
  linkPath String?
  entityType String?
  entityId   String?

  readAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  failureDetail String?
  /// True when delivered by a mock provider (spec section 28).
  simulated   Boolean @default(false)

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([companyId, type])
  @@map("notifications")
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  channel NotificationChannel
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@map("notification_preferences")
}

/// Polymorphic file attachment. Storage keys are private; access always goes
/// through a signed, permission-checked URL.
model Attachment {
  id        String @id @default(cuid())
  companyId String

  entityType String
  entityId   String

  storageKey   String
  originalName String
  mimeType     String
  sizeBytes    Int
  sha256       String
  scanStatus   DocumentScanStatus @default(PENDING)
  caption      String?

  uploadedById String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  asset             Asset?             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId           String?
  assetRequest      AssetRequest?      @relation(fields: [assetRequestId], references: [id], onDelete: Cascade)
  assetRequestId    String?
  maintenanceRecord MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  maintenanceRecordId String?

  @@index([companyId, entityType, entityId])
  @@index([sha256])
  @@map("attachments")
}

/// Spec section 10. One row per company; feature switches live in `featureModes`,
/// with per-office and per-role narrowing in AIFeatureOverride.
model AIConfiguration {
  id        String @id @default(cuid())
  companyId String @unique

  globallyEnabled Boolean   @default(false)
  pausedAt        DateTime?

  /// Map of AiFeature -> AiFeatureMode.
  featureModes Json

  confidenceThreshold Decimal @default(0.85) @db.Decimal(4, 3)
  monthlyBudgetUsd    Decimal? @db.Decimal(12, 2)
  monthlyRequestLimit Int?
  alertThresholdPct   Int      @default(80)
  retentionDays       Int      @default(365)

  /// Spec section 10 default: never true without an explicit, audited change.
  automaticFinancialApproval Boolean @default(false)
  humanReviewRequired        Boolean @default(true)

  providerName String @default("mock")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  version     Int      @default(0)

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  overrides AIFeatureOverride[]

  @@map("ai_configurations")
}

model AIFeatureOverride {
  id                String @id @default(cuid())
  aiConfigurationId String

  feature  AiFeature
  mode     AiFeatureMode
  officeId String?
  roleKey  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  configuration AIConfiguration @relation(fields: [aiConfigurationId], references: [id], onDelete: Cascade)
  office        Office?         @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([aiConfigurationId, feature, officeId, roleKey])
  @@map("ai_feature_overrides")
}

model AIUsageRecord {
  id        String @id @default(cuid())
  companyId String
  userId    String?

  feature  AiFeature
  provider String
  modelName String?

  entityType String?
  entityId   String?

  inputSummary   Json?
  extractedValues Json?
  confidence     Decimal? @db.Decimal(4, 3)
  suggestedResult Json?
  userCorrections Json?
  reviewerDecision String?

  durationMs Int?
  costUsd    Decimal? @db.Decimal(10, 6)
  succeeded  Boolean  @default(true)
  failureDetail String?
  simulated  Boolean  @default(false)

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, feature, createdAt])
  @@index([companyId, createdAt])
  @@map("ai_usage_records")
}

/// Append-only. Spec section 21: audit records must not be editable through the
/// normal application interface - there is no update or delete route for this model.
model AuditLog {
  id        String @id @default(cuid())
  companyId String

  actorId    String?
  action     AuditAction
  entityType String
  entityId   String

  previousValues Json?
  newValues      Json?
  reason         String?

  ipAddress     String?
  userAgent     String?
  clientType    String?
  correlationId String?

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, entityType, entityId, createdAt])
  @@index([companyId, actorId, createdAt])
  @@index([companyId, action, createdAt])
  @@index([correlationId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Physical inventory and reporting
// ─────────────────────────────────────────────────────────────────────────────

model PhysicalInventorySession {
  id        String @id @default(cuid())
  companyId String

  name     String
  officeId String?
  ownerId  String?
  status   PhysicalInventoryStatus @default(OPEN)

  startedAt   DateTime  @default(now())
  closedAt    DateTime?
  expectedCount Int?
  scannedCount  Int     @default(0)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  office  Office? @relation(fields: [officeId], references: [id], onDelete: SetNull)
  owner   User?   @relation("SessionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  scans   PhysicalInventoryScan[]

  @@index([companyId, status])
  @@map("physical_inventory_sessions")
}

model PhysicalInventoryScan {
  id        String @id @default(cuid())
  sessionId String

  assetId    String?
  scannedCode String
  result     PhysicalInventoryScanResult

  foundRoomId String?
  condition   AssetCondition?
  note        String?
  photoKey    String?

  /// Client-generated so an offline queue can replay without creating duplicates
  /// (spec section 16: queue offline changes, prevent conflicting updates).
  clientGeneratedId String   @unique
  scannedAt         DateTime
  syncedAt          DateTime @default(now())
  scannedById       String?

  session PhysicalInventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asset   Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  scannedBy User?                  @relation("ScanBy", fields: [scannedById], references: [id], onDelete: SetNull)

  @@index([sessionId, result])
  @@map("physical_inventory_scans")
}

model SavedFilter {
  id        String @id @default(cuid())
  companyId String
  userId    String

  name     String
  resource String
  filterJson Json
  isShared Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource, name])
  @@map("saved_filters")
}

model ScheduledReport {
  id        String @id @default(cuid())
  companyId String
  ownerId   String

  name       String
  resource   String
  filterJson Json?
  format     String @default("CSV")
  /// Standard 5-field cron expression, evaluated in the company timezone.
  cron       String
  recipients String[]
  isActive   Boolean @default(true)

  lastRunAt     DateTime?
  lastRunStatus String?
  nextRunAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([companyId, isActive, nextRunAt])
  @@map("scheduled_reports")
}
